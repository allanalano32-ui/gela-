# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo ".env" (com dados reais) para um repositório público.

# String de conexão do Postgres (Supabase: Project Settings -> Database -> Connection string)
DATABASE_URL=postgresql://usuario:senha@host:porta/postgres

# Senha única de acesso ao sistema (você escolhe)
GELA_PASSWORD=troque-esta-senha

# Chave secreta do Flask, usada para sessões de login (gere qualquer string aleatória longa)
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria-longa

# Chave de API do OpenAlex (gratuita).
# Obtenha em: https://openalex.org/ -> criar conta -> gerar API key
# Sem ela, o limite diário é de apenas 100 requisições (modo teste).
# Com ela, o limite sobe para 100.000 requisições/dia.
OPENALEX_API_KEY=

# E-mail para identificação educada nas requisições ao OpenAlex (recomendado pela documentação deles, não obrigatório)
OPENALEX_EMAIL=seu-email@exemplo.com

# PhilPapers: registro não é obrigatório para a maior parte da API pública,
# mas algumas funcionalidades exigem uma chave. Deixe em branco se não tiver.
# Obtenha em: https://philpapers.org/utils/create_api_user.html
PHILPAPERS_API_ID=
PHILPAPERS_API_KEY=

# Chave gratuita do Semantic Scholar (semanticscholar.org/product/api)
# Sem ela, o limite de requisições é um pool COMPARTILHADO globalmente
# entre todos os usuários não-autenticados (5.000 req/5min) - na prática
# estoura com facilidade e de forma imprevisível (é o 429 que vocês
# já pegaram). Com a chave, o limite passa a ser DEDICADO
# (1 req/segundo só para esta aplicação).
SEMANTIC_SCHOLAR_API_KEY=
